# ============================================
# Eco-Alert BRC - Variables de Entorno
# ============================================

# Entorno
NODE_ENV=development
PORT=3000

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eco_alert_brc
DB_USER=postgres
DB_PASSWORD=123456789

# JWT (mínimo 32 caracteres)
JWT_SECRET=eco-alert-brc-super-secret-key-2024-minimo-32-caracteres
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary (opcional para desarrollo local)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Google OAuth (opcional para desarrollo local)
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret

